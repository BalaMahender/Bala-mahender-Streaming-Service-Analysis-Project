"source": [
        "## Task 1: Data Ingestion & Quality Profiling"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "dd1aa207"
      },
      "source": [
        "### 1.1 Load & Inspect"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "cfe11efd"
      },
      "source": [
        "import pandas as pd\n",
        "\n",
        "# Load car_prices.csv into a pandas DataFrame using the absolute path\n",
        "try:\n",
        "    df = pd.read_csv('/content/car_prices.csv')\n",
        "    print(\"Dataset loaded successfully!\")\n",
        "except FileNotFoundError:\n",
        "    print(\"Error: 'car_prices.csv' not found. Please check the file path.\")\n",
        "    df = None\n",
        "\n",
        "if df is not None:\n",
        "    # Display the first 5 rows\n",
        "    print(\"\\nFirst 5 rows of the DataFrame:\")\n",
        "    display(df.head())\n",
        "\n",
        "    # Display data types and record count\n",
        "    print(\"\\nDataFrame Info (Data Types and Non-Null Counts):\")\n",
        "    df.info()"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "210f5aa4"
      },
      "source": [
        "### 1.2 Understanding the Data Structure"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "ccae2aeb"
      },
      "source": [
        "if df is not None:\n",
        "    # Check the shape of the dataset (rows and columns)\n",
        "    print(f\"\\nShape of the dataset (rows, columns): {df.shape}\")\n",
        "\n",
        "    # Display column names and data types (already covered by df.info(), but explicitly requested)\n",
        "    print(\"\\nColumn Names and their Data Types:\")\n",
        "    display(df.dtypes)"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "423ceafd"
      },
      "source": [
        "### 1.3 Missing & Anomaly Detection"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "4c96c8cd"
      },
      "source": [
        "if df is not None:\n",
        "    # Quantify nulls per column\n",
        "    print(\"\\nMissing values per column:\")\n",
        "    missing_values = df.isnull().sum()\n",
        "    missing_percentage = (df.isnull().sum() / len(df)) * 100\n",
        "    missing_df = pd.DataFrame({'Missing Count': missing_values, 'Missing Percentage': missing_percentage})\n",
        "    display(missing_df[missing_df['Missing Count'] > 0].sort_values(by='Missing Count', ascending=False))\n",
        "\n",
        "    # Visualize nulls with a bar chart\n",
        "    import matplotlib.pyplot as plt\n",
        "    import seaborn as sns\n",
        "\n",
        "    if not missing_df[missing_df['Missing Count'] > 0].empty:\n",
        "        plt.figure(figsize=(12, 6))\n",
        "        sns.barplot(x=missing_df.index, y=missing_df['Missing Count'], palette='viridis')\n",
        "        plt.xticks(rotation=90)\n",
        "        plt.title('Count of Missing Values Per Column')\n",
        "        plt.xlabel('Columns')\n",
        "        plt.ylabel('Missing Count')\n",
        "        plt.show()\n",
        "    else:\n",
        "        print(\"No missing values found to visualize.\")\n",
        "\n",
        "    # Count number of duplicate records\n",
        "    duplicate_rows = df.duplicated().sum()\n",
        "    print(f\"\\nNumber of duplicate rows: {duplicate_rows}\")\n",
        "\n",
        "    if duplicate_rows > 0:\n",
        "        print(\"\\nI've detected duplicate rows. We can remove them if desired. Please let me know if you'd like to proceed with removing them or if you'd like to analyze the duplicates further.\")\n",
        "    else:\n",
        "        print(\"No duplicate rows found.\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "303760ad"
      },
      "source": [
        "### 1.4 Data Imputation (Handling Missing Values)\n",
        "We will use the following strategy:\n",
        "- **Categorical Columns**: Fill with the most frequent value (mode).\n",
        "- **Numerical Columns**: Fill with the median to handle outliers better.\n",
        "- **Specific Columns**: For `transmission`, we will fill with the mode as it is a critical categorical feature."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "6171a3f3"
      },
      "source": [
        "if df is not None:\n",
        "    # Define categorical and numerical columns with missing values\n",
        "    cat_cols_to_fill = ['make', 'model', 'trim', 'body', 'transmission', 'vin', 'color', 'interior']\n",
        "    num_cols_to_fill = ['condition', 'odometer', 'mmr', 'sellingprice']\n",
        "\n",
        "    # Fill Categorical columns with Mode\n",
        "    for col in cat_cols_to_fill:\n",
        "        if col in df.columns:\n",
        "            df[col] = df[col].fillna(df[col].mode()[0])\n",
        "\n",
        "    # Fill Numerical columns with Median\n",
        "    for col in num_cols_to_fill:\n",
        "        if col in df.columns:\n",
        "            df[col] = df[col].fillna(df[col].median())\n",
        "\n",
        "    # Salidate remaining nulls\n",
        "    print(\"Missing values after imputation:\")\n",
        "    display(df.isnull().sum())\n",
        "\n",
        "    # Special handling for 'saledate' (dropping the very few rows with null dates if any)\n",
        "    df = df.dropna(subset=['saledate'])\n",
        "\n",
        "    print(f\"Final record count after cleaning: {len(df)}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "bc7eed67"
      },
      "source": [
        "### 1.5 Duplicate Removal\n",
        "Now that we have handled missing values, we will finalize the cleaning process by removing any duplicate records to ensure the integrity of our analysis."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "7d9bec97"
      },
      "source": [
        "if df is not None:\n",
        "    initial_count = len(df)\n",
        "    df = df.drop_duplicates()\n",
        "    final_count = len(df)\n",
        "\n",
        "    print(f\"Rows removed: {initial_count - final_count}\")\n",
        "    print(f\"Final dataset shape: {df.shape}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "576f2f89"
      },
      "source": [
        "## Task 2: Feature Engineering\n",
        "In this section, we will transform existing features and create new ones to improve the predictive power of our dataset. Key steps include:\n",
        "- Converting date strings to datetime objects.\n",
        "- Extracting temporal features (Year, Month).\n",
        "- Calculating the vehicle age at the time of sale."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "f03d85be"
      },
      "source": [
        "if df is not None:\n",
        "    # Ensure we are working on an explicit copy to avoid SettingWithCopyWarning\n",
        "    df = df.copy()\n",
        "\n",
        "    # 2.1 Convert saledate to datetime\n",
        "    # Using errors='coerce' turns malformed strings into NaT\n",
        "    df['saledate'] = pd.to_datetime(df['saledate'], utc=True, errors='coerce')\n",
        "\n",
        "    # Drop the 26 rows where date conversion failed to maintain data integrity\n",
        "    df = df.dropna(subset=['saledate'])\n",
        "\n",
        "    # 2.2 Extract Sale Year and Sale Month\n",
        "    df.loc[:, 'sale_year'] = df['saledate'].dt.year.astype(int)\n",
        "    df.loc[:, 'sale_month'] = df['saledate'].dt.month.astype(int)\n",
        "\n",
        "    # 2.3 Calculate Vehicle Age at time of sale\n",
        "    # We use abs() because some cars are sold just before their official 'model year'\n",
        "    df.loc[:, 'car_age'] = (df['sale_year'] - df['year']).abs()\n",
        "\n",
        "    # Display new features and validation\n",
        "    print(f\"Final record count after dropping failed date rows: {len(df)}\")\n",
        "    print(\"\\nSample of Engineered Features:\")\n",
        "    display(df[['year', 'saledate', 'sale_year', 'sale_month', 'car_age']].head())\n",
        "\n",
        "    # Check for anomalies\n",
        "    print(f\"\\nMinimum Car Age: {df['car_age'].min()}\")\n",
        "    print(f\"Nulls in saledate: {df['saledate'].isnull().sum()}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "843ddac6"
      },
      "source": [
        "### 2.4 Price Statistics\n",
        "Calculating the summary statistics for `sellingprice` to understand the price range and average value in the dataset."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "444ea4de"
      },
      "source": [
        "if df is not None:\n",
        "    min_price = df['sellingprice'].min()\n",
        "    max_price = df['sellingprice'].max()\n",
        "    avg_price = df['sellingprice'].mean()\n",
        "\n",
        "    print(f\"Minimum Car Price: ${min_price:,.2f}\")\n",
        "    print(f\"Maximum Car Price: ${max_price:,.2f}\")\n",
        "    print(f\"Average Car Price: ${avg_price:,.2f}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "bf3f7946"
      },
      "source": [
        "### 2.5 Price Distribution Visualization\n",
        "Visualizing the `sellingprice` to identify the distribution shape and potential outliers."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "9c2bceef"
      },
      "source": [
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "if df is not None:\n",
        "    plt.figure(figsize=(15, 6))\n",
        "\n",
        "    # Histogram\n",
        "    plt.subplot(1, 2, 1)\n",
        "    sns.histplot(df['sellingprice'], bins=50, kde=True, color='skyblue')\n",
        "    plt.title('Distribution of Selling Price')\n",
        "    plt.xlabel('Selling Price ($)')\n",
        "\n",
        "    # Boxplot\n",
        "    plt.subplot(1, 2, 2)\n",
        "    sns.boxplot(x=df['sellingprice'], color='lightcoral')\n",
        "    plt.title('Boxplot of Selling Price')\n",
        "    plt.xlabel('Selling Price ($)')\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "3c979175"
      },
      "source": [
        "### 2.6 Outlier Treatment\n",
        "Based on the visualizations, we need to:\n",
        "1. Filter out non-market prices (e.g., prices below $100).\n",
        "2. Cap or remove extreme outliers to normalize the distribution for modeling."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "4078c15a"
      },
      "source": [
        "if df is not None:\n",
        "    # 1. Filter out unrealistic 'placeholder' prices (under $100)\n",
        "    initial_rows = len(df)\n",
        "    df = df[df['sellingprice'] >= 100]\n",
        "\n",
        "    # 2. Calculate IQR for sellingprice\n",
        "    Q1 = df['sellingprice'].quantile(0.25)\n",
        "    Q3 = df['sellingprice'].quantile(0.75)\n",
        "    IQR = Q3 - Q1\n",
        "\n",
        "    # Define upper bound for outliers (using 1.5 * IQR)\n",
        "    upper_bound = Q3 + 1.5 * IQR\n",
        "\n",
        "    # Cap outliers at the upper bound instead of dropping to retain high-value car data\n",
        "    # but reduce its variance impact, or we can filter them out.\n",
        "    # Let's filter out extreme outliers to keep the distribution tighter for this exercise.\n",
        "    df = df[df['sellingprice'] <= upper_bound]\n",
        "\n",
        "    final_rows = len(df)\n",
        "    print(f\"Rows removed during outlier cleaning: {initial_rows - final_rows}\")\n",
        "    print(f\"New price range: ${df['sellingprice'].min():,.2f} to ${df['sellingprice'].max():,.2f}\")\n",
        "\n",
        "    # Quick view of cleaned distribution\n",
        "    plt.figure(figsize=(8, 4))\n",
        "    sns.histplot(df['sellingprice'], bins=30, kde=True, color='green')\n",
        "    plt.title('Cleaned Selling Price Distribution')\n",
        "    plt.show()"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "4a0ab5c3"
      },
      "source": [
        "### 2.7 One-Hot Encoding\n",
        "We will now use `pd.get_dummies` to encode `body` and `transmission`. To avoid the 'dummy variable trap' and keep the dataset manageable, we will set `drop_first=True`."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "1425a884"
      },
      "source": [
        "if df is not None:\n",
        "    # Define low-cardinality features for One-Hot Encoding\n",
        "    oh_cols = ['body', 'transmission']\n",
        "\n",
        "    # Perform One-Hot Encoding\n",
        "    # drop_first=True reduces multicollinearity by dropping one level of each feature\n",
        "    df_encoded = pd.get_dummies(df, columns=oh_cols, drop_first=True)\n",
        "\n",
        "    print(f\"Original shape: {df.shape}\")\n",
        "    print(f\"New shape after One-Hot Encoding: {df_encoded.shape}\")\n",
        "\n",
        "    # Display new dummy columns\n",
        "    new_cols = [c for c in df_encoded.columns if any(sub in c for sub in oh_cols)]\n",
        "    print(f\"\\nCreated {len(new_cols)} dummy variables.\")\n",
        "    display(df_encoded[new_cols].head())"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "53dd9e65"
      },
      "source": [
        "### 2.8 Frequency Encoding\n",
        "To handle high-cardinality features like `make` and `model` without creating thousands of new columns, we use **Frequency Encoding**. This replaces each category with its frequency (count) in the dataset."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "db7701ee"
      },
      "source": [
        "if df_encoded is not None:\n",
        "    # Define columns for frequency encoding\n",
        "    freq_cols = ['make', 'model']\n",
        "\n",
        "    for col in freq_cols:\n",
        "        # Calculate frequency for each category\n",
        "        freq = df_encoded[col].value_counts().to_dict()\n",
        "\n",
        "        # Map frequencies back to the dataframe\n",
        "        df_encoded[col + '_freq'] = df_encoded[col].map(freq)\n",
        "\n",
        "    # Display the result for the new frequency columns\n",
        "    print(\"Frequency encoding complete.\")\n",
        "    display(df_encoded[['make', 'make_freq', 'model', 'model_freq']].head())\n",
        "\n",
        "    # Optionally drop original columns if no longer needed for further categorical work\n",
        "    # df_encoded = df_encoded.drop(columns=freq_cols)"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "acfbb6f3"
      },
      "source": [
        "### 2.9 Finalizing Categorical Features\n",
        "We will now apply frequency encoding to the `trim` column and drop the original high-cardinality and non-predictive categorical columns to finalize the feature engineering dataset."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "74a59ea1"
      },
      "source": [
        "if df_encoded is not None:\n",
        "    # 1. Frequency encode 'trim'\n",
        "    trim_freq = df_encoded['trim'].value_counts().to_dict()\n",
        "    df_encoded['trim_freq'] = df_encoded['trim'].map(trim_freq)\n",
        "\n",
        "    # 2. Define columns to drop (original categories and identifiers)\n",
        "    cols_to_drop = ['make', 'model', 'trim', 'vin', 'seller', 'state', 'saledate', 'color', 'interior']\n",
        "\n",
        "    # Drop columns that exist in the dataframe\n",
        "    existing_cols_to_drop = [c for c in cols_to_drop if c in df_encoded.columns]\n",
        "    df_final = df_encoded.drop(columns=existing_cols_to_drop)\n",
        "\n",
        "    print(f\"Frequency encoding for 'trim' complete.\")\n",
        "    print(f\"Dropped {len(existing_cols_to_drop)} original columns.\")\n",
        "    print(f\"Final Dataset Shape: {df_final.shape}\")\n",
        "\n",
        "    # Display first few rows of the final processed dataset\n",
        "    display(df_final.head())"
      ],
      "execution_count": null,
      "outputs": []
    },
